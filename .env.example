# APPLICATION
APP_ENV=development
APP_SECRET_KEY=
APP_HOST=0.0.0.0
APP_PORT=8000
ALLOWED_ORIGINS=http://localhost:3000

# LLM PROVIDER
LLM_PROVIDER=groq
GROQ_API_KEY=
ANTHROPIC_API_KEY=

# POSTGRESQL
DATABASE_URL=postgresql+asyncpg://nyayasetu:password@localhost:5432/nyayasetu
TEST_DATABASE_URL=postgresql+asyncpg://test_user:test_pass@localhost:5433/nyayasetu_test

# QDRANT
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=nyayasetu_clauses
QDRANT_API_KEY=

# NEO4J
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=nyayasetu_dev

# EMBEDDING MODEL
EMBEDDING_MODEL_NAME=intfloat/multilingual-e5-large
EMBEDDING_BATCH_SIZE=32
EMBEDDING_DEVICE=cpu

# RAZORPAY
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# EMAIL (SMTP)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=
EMAIL_FROM=noreply@nyayasetu.in
EMAIL_FROM_NAME=NyayaSetu

# JWT
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# PIPELINE CONFIGURATION
CONFIDENCE_ESCALATION_THRESHOLD=0.45
FREE_TIER_MONTHLY_LIMIT=3
QDRANT_TOP_K_PER_QUERY=5
NEO4J_TRAVERSAL_DEPTH=2
MAX_CLAUSES_RETURNED=10

# FEATURE FLAGS
FF_WRITEUP_ENABLED=true
FF_GUEST_MODE=true
FF_GRAPH_TRAVERSAL=true
FF_PAYMENT_REQUIRED=true
FF_ESCALATION_ENABLED=true
